{
  "name": "mercadoagro-mobile-api",
  "version": "0.1.0",
  "private": true,
  "description": "API REST mobile-first para o MercadoAgro.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.11.0 <25"
  },
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js || (npm run build && node dist/main.js)",
    "test": "npm run build && node test/run.js",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.1",
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.1",
    "@fastify/static": "^8.2.0",
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.6",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/throttler": "^6.4.0",
    "@prisma/adapter-neon": "^6.19.2",
    "@prisma/client": "^6.15.0",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "fastify": "^5.6.0",
    "nodemailer": "^7.0.5",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "redis": "^5.8.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^24.3.1",
    "@types/nodemailer": "^7.0.1",
    "@types/passport-jwt": "^3.0.3",
    "@types/ws": "^8.18.1",
    "dotenv": "^17.2.2",
    "ms": "^2.1.3",
    "prisma": "^6.15.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3"
  }
}
