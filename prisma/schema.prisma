generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum ListingStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ListingCondition {
  NOVA
  SEMINOVA
}

model User {
  id                      String                   @id @default(uuid())
  email                   String                   @unique
  passwordHash            String
  fullName                String
  role                    UserRole                 @default(USER)
  phone                   String?
  avatarUrl               String?
  cpfCnpj                 String?
  termsAcceptedAt         DateTime?
  privacyAcceptedAt       DateTime?
  termsVersion            String?
  emailVerifiedAt         DateTime?
  deletedAt               DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  listings                Listing[]
  refreshTokens           RefreshToken[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  auditLogs               AuditLog[]
}

model RefreshToken {
  id          String    @id
  userId      String
  hashedToken String
  expiresAt   DateTime
  revokedAt   DateTime?
  userAgent   String?
  ipAddress   String?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailVerificationToken {
  id         String    @id @default(uuid())
  userId     String
  tokenHash  String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tokenHash])
  @@index([expiresAt])
}

model PasswordResetToken {
  id         String    @id @default(uuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Listing {
  id               String           @id @default(uuid())
  title            String
  description      String
  category         String?
  brand            String?
  modelName        String?
  manufacturingYear Int?
  condition        ListingCondition?
  hourmeterHours   Int?
  powerCv          Int?
  accessories      String[]          @default([])
  price            Decimal           @db.Decimal(12, 2)
  imageUrl         String?
  locationCity     String?
  locationState    String?
  lat              Float?
  lng              Float?
  status           ListingStatus     @default(DRAFT)
  deletedAt        DateTime?
  sellerId         String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  seller           User              @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  photos           Photo[]

  @@index([sellerId])
  @@index([status, createdAt])
  @@index([deletedAt])
}

model Photo {
  id        String   @id @default(uuid())
  listingId String
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  event      String
  targetType String?
  targetId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([event, createdAt])
  @@index([userId, createdAt])
}
