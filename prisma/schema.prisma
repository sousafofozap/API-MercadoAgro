generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum ListingStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id                      String                   @id @default(uuid())
  email                   String                   @unique
  passwordHash            String
  fullName                String
  role                    UserRole                 @default(USER)
  phone                   String?
  avatarUrl               String?
  emailVerifiedAt         DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  listings                Listing[]
  refreshTokens           RefreshToken[]
  emailVerificationTokens EmailVerificationToken[]
  auditLogs               AuditLog[]
}

model RefreshToken {
  id          String   @id
  userId      String
  hashedToken String
  expiresAt   DateTime
  revokedAt   DateTime?
  userAgent   String?
  ipAddress   String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailVerificationToken {
  id         String   @id @default(uuid())
  userId     String
  tokenHash  String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tokenHash])
  @@index([expiresAt])
}

model Listing {
  id            String        @id @default(uuid())
  title         String
  description   String
  category      String?
  price         Decimal       @db.Decimal(12, 2)
  locationCity  String?
  locationState String?
  imageUrl      String?
  status        ListingStatus @default(DRAFT)
  sellerId      String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  seller        User          @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
  @@index([status, createdAt])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  event      String
  targetType String?
  targetId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([event, createdAt])
  @@index([userId, createdAt])
}
