NODE_ENV=development
PORT=3000
APP_NAME=MercadoAgro Mobile API
API_PREFIX=v1
TRUST_PROXY=false
DATABASE_URL=postgresql://USER:PASSWORD@YOUR-NEON-POOLER-HOST/mercadoagro?sslmode=require&channel_binding=require&connect_timeout=15
DIRECT_URL=postgresql://USER:PASSWORD@YOUR-NEON-DIRECT-HOST/mercadoagro?sslmode=require&channel_binding=require&connect_timeout=15
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
PUBLIC_THROTTLE_LIMIT=20
MAIL_DRIVER=logger
MAIL_FROM_NAME=MercadoAgro
MAIL_FROM_ADDRESS=no-reply@mercadoagro.local
MAIL_REPLY_TO=support@mercadoagro.local
EMAIL_VERIFICATION_URL_TEMPLATE=mercadoagro://verify-email?token={{token}}
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SEED_ADMIN_PASSWORD=Admin@123456
SEED_USER_PASSWORD=User@123456
